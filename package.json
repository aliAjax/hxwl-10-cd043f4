{
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5110",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5110",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "quality": "npm run typecheck && npm run test",
    "quality:ci": "npm run typecheck && npm run build && npm run test",
    "quality:full": "npm run typecheck && npm run build && npm run test:coverage",
    "verify:storage": "vitest run src/indexedDB.test.ts src/export/exportTaskStore.test.ts",
    "verify:export": "vitest run src/export/jsonExporter.test.ts src/export/dataCollector.test.ts src/export/consistencyChecker.test.ts",
    "verify:chronology": "vitest run src/chronologyInference.test.ts",
    "verify:validators": "vitest run src/domainValidators.test.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.9",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "jsdom-worker": "^0.3.0",
    "vitest": "^2.1.8"
  }
}
